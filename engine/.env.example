# Supabase (service role for engine — never commit real keys)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# LLM — at least one
GOOGLE_API_KEY=
GROQ_API_KEY=

# Umami (self-hosted) API — used by TrafficMonitor
UMAMI_URL=https://your-umami.vercel.app
UMAMI_API_TOKEN=

# Optional: master key for decrypting Stripe secrets stored per-business (must match web app)
STRIPE_SECRET_ENCRYPTION_KEY=

# Engine behaviour
ENGINE_TIMEZONE=Europe/London
