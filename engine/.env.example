# Supabase (service role for engine — never commit real keys)
# Same URL/key as web: engine/config loads ../web/.env.local automatically when present.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# LLM — at least one for `python main.py full`
GOOGLE_API_KEY=
GROQ_API_KEY=
# When Gemini free tier hits limit:0 / 429, add GROQ_API_KEY — Crew retries with Groq automatically.
# Or set ENGINE_FORCE_GROQ=1 to skip Gemini for Crew entirely.
ENGINE_FORCE_GROQ=0
# google.generativeai model id (enqueue_three_pending_posts_direct)
GEMINI_TEXT_MODEL=gemini-2.0-flash
# CrewAI / LiteLLM-style id — must match an API-available Gemini model
CREWAI_GEMINI_MODEL=gemini/gemini-2.0-flash

# Umami API (engine reads UMAMI_URL or NEXT_PUBLIC_UMAMI_URL from web/.env.local)
UMAMI_URL=https://cloud.umami.is
UMAMI_API_TOKEN=

# Optional: decrypt Stripe secrets saved per-business in DB (must match web STRIPE_SECRET_ENCRYPTION_KEY)
STRIPE_SECRET_ENCRYPTION_KEY=

# Engine behaviour (optional)
ENGINE_TIMEZONE=Europe/London
# Seconds to sleep between businesses in run_all() (0 = no delay). CI sets ~20 when using Groq.
ENGINE_SLEEP_BETWEEN_BUSINESSES_SEC=0
