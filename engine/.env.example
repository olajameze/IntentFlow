# Supabase (service role for engine — never commit real keys)
# Actions: repo secret SUPABASE_URL (recommended). Optional fallback: NEXT_PUBLIC_SUPABASE_URL = same HTTPS URL.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# LLM — at least one for `python main.py full`
GOOGLE_API_KEY=
GROQ_API_KEY=

# Umami API (engine reads UMAMI_URL, not NEXT_PUBLIC_UMAMI_URL — match GitHub Actions secrets)
UMAMI_URL=https://cloud.umami.is
UMAMI_API_TOKEN=

# Optional: decrypt Stripe secrets saved per-business in DB (must match web STRIPE_SECRET_ENCRYPTION_KEY)
STRIPE_SECRET_ENCRYPTION_KEY=

# Engine behaviour (optional)
ENGINE_TIMEZONE=Europe/London
