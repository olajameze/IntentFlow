# Supabase (service role for engine — never commit real keys)
# Same URL/key as web: engine/config loads ../web/.env.local automatically when present.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# LLM — pick one path for `python main.py full`
#
# Groq-only (recommended — no Gemini):
#   Set GROQ_API_KEY. Omit GOOGLE_API_KEY entirely (or leave empty) — the engine then uses Groq only without any flag.
#   Optional: ENGINE_USE_GROQ_ONLY=1 if you keep a Google key on disk but want to force Groq anyway.
GROQ_API_KEY=
ENGINE_USE_GROQ_ONLY=0
ENGINE_FORCE_GROQ=0
#
# Optional Gemini (only if GOOGLE_API_KEY is set and Groq-only flags are off):
# GOOGLE_API_KEY=
# google.generativeai model id (pending-post copy when Gemini is used)
GEMINI_TEXT_MODEL=gemini-2.0-flash
# CrewAI / LiteLLM-style id when Gemini is used
CREWAI_GEMINI_MODEL=gemini/gemini-2.0-flash

# Umami — engine reads UMAMI_URL or NEXT_PUBLIC_UMAMI_URL from web/.env.local
# Umami Cloud: keep NEXT_PUBLIC_UMAMI_URL=https://cloud.umami.is for the dashboard link, but the
# engine calls https://api.umami.is/v1 with header x-umami-api-key. Put your Cloud API key in
# UMAMI_API_KEY (preferred) or UMAMI_API_TOKEN. Create the key: Cloud → Settings → API keys.
UMAMI_URL=https://cloud.umami.is
UMAMI_API_KEY=
UMAMI_API_TOKEN=
# Optional explicit API root (overrides auto Cloud detection), e.g. https://api.umami.is/v1/us
# UMAMI_API_CLIENT_ENDPOINT=
# UMAMI_CLOUD_REGION=us

# Must match web STRIPE_SECRET_ENCRYPTION_KEY and GitHub Actions secret STRIPE_SECRET_ENCRYPTION_KEY (openssl rand -hex 32).
STRIPE_SECRET_ENCRYPTION_KEY=

# ── Ollama local fallback ─────────────────────────────────────────────────────
# When ENGINE_USE_OLLAMA_FALLBACK=1 the engine tries a local Ollama server if Groq
# returns empty (rate-limited, bad key, network error). No API credits required.
#
# Local setup:  https://ollama.com/download  then:  ollama pull llama3.2:1b
# GitHub Actions: workflow provisions Ollama automatically when this flag is set.
ENGINE_USE_OLLAMA_FALLBACK=0
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Recommended lightweight models (fastest first):
#   llama3.2:1b   ~770 MB — good quality for short social posts
#   llama3.2:3b   ~2 GB  — noticeably better copy quality
#   mistral:7b    ~4 GB  — best quality, slower pull on CI
OLLAMA_TEXT_MODEL=llama3.2:1b
# Seconds to wait for an Ollama response (default 120 — local inference can be slow on first run).
# OLLAMA_TIMEOUT_SEC=120

# ── Engine behaviour (optional) ───────────────────────────────────────────────
ENGINE_TIMEZONE=Europe/London
# Seconds to sleep between businesses in run_all() (0 = no delay). CI sets ~20 when using Groq.
ENGINE_SLEEP_BETWEEN_BUSINESSES_SEC=0
# Groq free tier hits TPM across many Crew tasks — retries with backoff on crew.kickoff().
ENGINE_CREW_KICKOFF_RETRIES=8
# Fallback pause (seconds) when Groq does not return a "try again in Xs" hint.
ENGINE_GROQ_RATE_LIMIT_PAUSE_SEC=15
# Groq retries per individual copy generation call (not Crew kickoff).
GROQ_TEXT_RETRIES=3
# Override Groq model for copy generation (default: llama-3.1-8b-instant).
# GROQ_TEXT_MODEL=llama-3.3-70b-versatile
