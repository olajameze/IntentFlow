# --- Root (monorepo) ---
node_modules/
.DS_Store
*.pem
.env
.env.local
.env.*.local

# Next.js (web/) — `node_modules/` above covers web too
web/.next/
web/out/
web/build/
web/.vercel
web/*.tsbuildinfo
web/npm-debug.log*
web/yarn-debug.log*
web/yarn-error.log*

# Python (engine/)
engine/.venv/
engine/**/__pycache__/
engine/**/*.pyc
engine/.env

# Playwright (web/)
web/playwright-report/
web/test-results/
web/blob-report/

# Large vendor PDFs (keep locally — see docs/references/README.md)
docs/references/*.pdf

# Tools / local (includes engine/tools/llm.py debug telemetry)
.idea/
.vscode/
*.log
*.stackdump

.vercel
.env*.local
