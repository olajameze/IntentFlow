{
  "name": "intentflow",
  "private": true,
  "description": "Root scripts forward to web/ — Next.js app lives in web/. Root devDependencies mirror web next/react for Vercel when Root Directory is the repo root.",
  "devDependencies": {
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18"
  },
  "scripts": {
    "dev": "npm run dev --prefix web",
    "build": "npm run build --prefix web",
    "start": "npm run start --prefix web",
    "lint": "npm run lint --prefix web",
    "install:web": "npm install --prefix web",
    "test:e2e": "npm run test:e2e --prefix web",
    "test:e2e:integration": "npm run test:e2e:integration --prefix web",
    "engine:traffic": "npm run engine:traffic --prefix web",
    "engine:full": "npm run engine:full --prefix web",
    "engine:revenue": "npm run engine:revenue --prefix web"
  }
}
