{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "dev:webpack": "next dev",
    "dev:turbo": "next dev --turbo",
    "clean": "node scripts/clean-next.mjs",
    "dev:clean": "npm run clean && next dev --turbo",
    "dev:clean:webpack": "npm run clean && next dev",
    "dev:clean:turbo": "npm run clean && next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "npx --yes tsx --test src/lib/outreach/*.test.ts",
    "postinstall": "patch-package",
    "test:e2e": "playwright test",
    "test:e2e:integration": "cross-env PLAYWRIGHT_INTEGRATION=true playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "engine:traffic": "cd ../engine && python main.py traffic",
    "engine:full": "cd ../engine && python main.py full",
    "engine:revenue": "cd ../engine && python main.py revenue",
    "setup:conversion": "node scripts/setup-marketing-conversion.mjs",
    "setup:conversion:sql": "node scripts/open-migration-sql-editor.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@ducanh2912/next-pwa": "^10.2.9",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "@types/nodemailer": "^8.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.14.0",
    "next": "14.2.35",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.7",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^3.8.1",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "cross-env": "^7.0.3",
    "dotenv": "^16.6.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "patch-package": "^8.0.1",
    "pg": "^8.21.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
