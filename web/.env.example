NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# Use either name for the public Supabase key (same value as Project Settings → API → anon/publishable).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Dashboard API routes (server-only): optional if you only use SSR + RLS with anon key
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_ENCRYPTION_KEY=generate-a-long-random-string
# Generate once: openssl rand -hex 32  (same value in engine/.env + GitHub secret STRIPE_SECRET_ENCRYPTION_KEY)
# Optional — vault via `npm run vault:stripe-keys` (restricted Stripe secret keys per brand):
# STRIPE_SECRET_KEY_WEATHERS=rk_live_...
# STRIPE_SECRET_KEY_PESTTRACE=rk_live_...
# STRIPE_SECRET_KEY_JGDEVS=rk_live_...
# Microsoft Clarity Data Export API — optional global fallback if a brand has no vaulted token.
# Preferred: save one token per brand in Settings → Active portfolio → Clarity API token.
CLARITY_API_TOKEN=
# Clarity lookback per sync (1–3 days only; API limit).
CLARITY_SNAPSHOT_DAYS=3
# Stripe revenue window for traffic job (days).
TRAFFIC_SNAPSHOT_DAYS=30

# Facebook Graph API — simplest: one Page for all businesses
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
# Or map Supabase businesses.id UUIDs to numbered Page credentials (use _1 … _5, not bare FACEBOOK_BUSINESS_ID):
# FACEBOOK_BUSINESS_ID_1=11111111-1111-1111-1111-111111111111
FACEBOOK_PAGE_ID_1=
FACEBOOK_PAGE_ACCESS_TOKEN_1=
FACEBOOK_PAGE_ID_2=
FACEBOOK_PAGE_ACCESS_TOKEN_2=
FACEBOOK_PAGE_ID_3=
FACEBOOK_PAGE_ACCESS_TOKEN_3=

# Optional — dashboard “Run engine now” POST /api/trigger-engine
# Fine-grained PAT on this repo: Actions → Write, Contents → Read.
GITHUB_ACTION_DISPATCH_TOKEN=
# Same PAT is accepted under any one of these names (only set one):
# GITHUB_DISPATCH_TOKEN=
# GH_DISPATCH_TOKEN=
# Repo slug — either variable works for dispatch (`GITHUB_REPOSITORY` is server-only preference):
GITHUB_REPOSITORY=
NEXT_PUBLIC_GITHUB_REPO=your-org/IntentFlow
# Optional branch for workflow_dispatch (default main)
# ENGINE_WORKFLOW_REF=main
# Optional: branch for traffic-revenue-sync.yml only (falls back to ENGINE_WORKFLOW_REF)
# TRAFFIC_WORKFLOW_REF=main

# Traffic page — POST /api/trigger-traffic-sync dispatches traffic-revenue-sync.yml (same PAT + repo as trigger-engine)

# Dev only: override Next dev output dir (default: .next-dev). Example: .next
# NEXT_DIST_DIR=.next

# Set to 1 to enable the PWA service worker during `next dev` (e.g. test install from a phone on your LAN).
# NEXT_PUBLIC_ENABLE_PWA_DEV=0

# Outreach conversion (see docs/outreach-conversion-webhook.md)
# OUTREACH_PUBLIC_BASE_URL=https://your-dashboard.vercel.app
# OUTREACH_SNAPSHOT_ENABLED=1
# OUTREACH_VISUAL_AUDIT_ENABLED=1
# GEMINI_VISION_MODEL=gemini-2.0-flash
# CRON_SECRET=
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[PASSWORD]@...pooler.supabase.com:6543/postgres
# OUTREACH_CONVERSION_SECRET=
# BREVO_WEBHOOK_SECRET=
# BREVO_API_KEY=
# OUTREACH_HOURLY_SEND_LIMIT=30
# OUTREACH_SEND_WINDOW_MINUTES=20
# OUTREACH_REPLY_IMAP_HOST=
# OUTREACH_REPLY_IMAP_USER=
# OUTREACH_REPLY_IMAP_PASSWORD=
# OUTREACH_DASHBOARD_URL=https://your-dashboard.vercel.app
# Outreach platform v2 (inbox, alerts, HubSpot, smart send, auth)
# HUBSPOT_ACCESS_TOKEN=
# HUBSPOT_PIPELINE_ID=
# HUBSPOT_WEBHOOK_SECRET=
# CALENDLY_WEBHOOK_SECRET=
# OUTREACH_ALERT_FROM_EMAIL=
# OUTREACH_ALERT_TO_EMAIL=
# OUTREACH_SMART_SEND=1
# OUTREACH_REQUIRE_AUTH=0
# JGDevs outreach (campaign: jgdevs — UK small businesses)
# JGDEVS_OUTREACH_FROM_NAME=JGDevs
# JGDEVS_OUTREACH_FROM_EMAIL=hello@jgdev.co.uk
# JGDEVS_SMTP_HOST=smtp.example.com
# JGDEVS_SMTP_PORT=587
# JGDEVS_SMTP_USER=
# JGDEVS_SMTP_PASSWORD=
# Breazy Productions outreach (campaign: breazy — UK videography)
# BREAZY_OUTREACH_FROM_NAME=Breazy Productions
# BREAZY_OUTREACH_FROM_EMAIL=breazyproductions7@gmail.com
# BREAZY_SMTP_HOST=smtp.example.com
# BREAZY_SMTP_PORT=587
# BREAZY_SMTP_USER=
# BREAZY_SMTP_PASSWORD=
