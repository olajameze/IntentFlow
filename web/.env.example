NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Dashboard API routes (server-only): optional if you only use SSR + RLS with anon key
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_ENCRYPTION_KEY=generate-a-long-random-string
NEXT_PUBLIC_UMAMI_URL=https://cloud.umami.is

# Facebook Graph API — one Page per numbered set (long-lived Page tokens). Add more pairs if needed.
FACEBOOK_PAGE_ID_1=
FACEBOOK_PAGE_ACCESS_TOKEN_1=
FACEBOOK_PAGE_ID_2=
FACEBOOK_PAGE_ACCESS_TOKEN_2=
FACEBOOK_PAGE_ID_3=
FACEBOOK_PAGE_ACCESS_TOKEN_3=

# Optional — "Run engine now" POST /api/trigger-engine (fine-grained PAT: Actions Write + Contents Read)
GITHUB_ACTION_DISPATCH_TOKEN=
GITHUB_REPOSITORY=your-org/IntentFlow
# Optional — branch/ref for workflow_dispatch (default main)
# ENGINE_WORKFLOW_REF=main
# Fallback link only (public): repo slug for Actions URL when dispatch token unset
NEXT_PUBLIC_GITHUB_REPO=your-org/IntentFlow

# Dev only: override Next dev output dir (default: .next-dev). Example: .next
# NEXT_DIST_DIR=.next
